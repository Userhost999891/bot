# ================================
# NarisMC Core Bot - Config
# ================================

# Discord Bot Token (z Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Application Client ID
DISCORD_CLIENT_ID=your_client_id_here

# Discord Application Client Secret
DISCORD_CLIENT_SECRET=your_client_secret_here

# OAuth2 Callback URL (zmień na swój adres po hostingu!)
CALLBACK_URL=https://your-domain.com/auth/callback

# Tajny klucz sesji (zmień na losowy ciąg znaków!)
SESSION_SECRET=zmien_na_losowy_klucz_sesji_123!

# Port serwera web
PORT=4000

# ================================
# MySQL — System Nagród
# ================================
MYSQL_HOST=your_mysql_host
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=your_mysql_database

# ================================
# Hosting
# ================================
# Ustaw na URL twojej aplikacji (bez / na końcu)
# np. https://narismc-bot.railway.app
APP_URL=http://localhost:4000
